# Frontend
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Vercel / public app base
PUBLIC_APP_URL=https://envpro.com.br
APP_BASE_URL=https://envpro.com.br

# Supabase edge functions
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Local CLI publish helper
SUPABASE_DB_PASSWORD=YOUR_REMOTE_DATABASE_PASSWORD

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email
RESEND_API_KEY=re_xxx
SYSTEM_EMAIL_FROM=envPRO <onboarding@resend.dev>

# Firecrawl
FIRECRAWL_API_KEY=fc_xxx

# Meta WhatsApp Cloud API
META_WHATSAPP_VERIFY_TOKEN=choose_a_random_verify_token
META_WHATSAPP_APP_SECRET=your_meta_app_secret
META_WHATSAPP_ACCESS_TOKEN=EAA...
META_WHATSAPP_PHONE_NUMBER_ID=1234567890

# ElevenLabs
ELEVENLABS_API_KEY=elevenlabs_xxx

# n8n outbound campaign webhook
N8N_CAMPAIGN_WEBHOOK_URL=https://your-n8n-host/webhook/...
N8N_CAMPAIGN_WEBHOOK_SECRET=optional_shared_secret
